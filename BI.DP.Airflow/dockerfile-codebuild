FROM --platform=linux/amd64  debian as interim
RUN apt update && apt install -y git
RUN mkdir -p -m 0700 ~/.ssh && ssh-keyscan github.com >> ~/.ssh/known_hosts
ARG DBT_BRANCH
ENV DBT_BRANCH=$DBT_BRANCH
ENV DBT_DIR /dbt
WORKDIR /
RUN --mount=type=ssh \
   git clone --depth=1 git@github.com:your-org/BI.DP.DBT.git -b $DBT_BRANCH $DBT_DIR
# Delete the env directories in each DBT project - they are not necessary and increase the image size
RUN find $DBT_DIR -type d -maxdepth 2 -name 'env' -exec rm -rf {} \; || echo continue
RUN find $DBT_DIR -type d -maxdepth 2 -name 'build' -exec rm -rf {} \; || echo continue
RUN find $DBT_DIR -type d -maxdepth 3 -name 'dbt_utils' -exec rm -rf {} \; || echo continue
#RUN find $DBT_DIR -type d -maxdepth 3 -name 'macros' -exec rm -rf {} \; || echo continue

FROM apache/airflow:2.8.3-python3.11
ENV DBT_DIR /opt/airflow/dags/dbt
COPY airflow_airbyte/dags /opt/airflow/dags
COPY --from=interim /dbt $DBT_DIR

USER root
RUN apt update && apt install -y git
RUN chmod -R 775 /opt/airflow/dags
RUN apt install -y libglib2.0-0 libnspr4 libnss3 libxcb1 libxcb-xkb1 ffmpeg chromium wget unzip chromium-driver \
    pkg-config default-libmysqlclient-dev build-essential

COPY requirements.txt /requirements.txt
# Install uv and use it for faster package installation (bypasses Airflow's pip wrapper)
# Also remove conflicting packages from airflow user's local site-packages
RUN python -m pip install --no-cache-dir uv && \
    rm -rf /home/airflow/.local/lib/python3.11/site-packages/google* \
           /home/airflow/.local/lib/python3.11/site-packages/protobuf* \
           /home/airflow/.local/lib/python3.11/site-packages/sqlalchemy_spanner* && \
    python -m uv pip install --system --no-cache "apache-airflow==2.8.3" -r /requirements.txt

# Switch to airflow user for dbt deps and parse
USER airflow

# DBT Environment Variables (needed for dbt parse to read profiles.yml)
ARG DBT_ACCOUNT
ARG DBT_WAREHOUSE
ARG DBT_DATABASE
ARG DBT_ROLE
ARG DBT_USER
ARG DBT_PASSWORD

ENV DBT_ACCOUNT=$DBT_ACCOUNT
ENV DBT_WAREHOUSE=$DBT_WAREHOUSE
ENV DBT_DATABASE=$DBT_DATABASE
ENV DBT_ROLE=$DBT_ROLE
ENV DBT_USER=$DBT_USER
ENV DBT_PASSWORD=$DBT_PASSWORD

# Run dbt deps for all projects, and compile where possible to generate manifest.json
# dbt compile generates manifest.json + compiled SQL for faster Cosmos DAG parsing
# Note: Some projects may fail to compile due to missing env vars - that's OK, they'll use dbt ls at runtime
RUN cd $DBT_DIR \
    && for dir in */ ; do \
        if [ -d "$dir/$dir" ]; then \
            cd ${dir}/${dir}; \
            echo "=== Processing $dir ==="; \
            dbt deps; \
            dbt compile || echo "Compile skipped for $dir (missing env vars)"; \
            cd $DBT_DIR; \
        fi; \
    done

# ARG FOR SECRET
ARG host
ARG user
ARG password

ARG snowflake_user
ARG snowflake_password
ARG snowflake_account
ARG snowflake_warehouse
ARG snowflake_database
ARG snowflake_schema
ARG snowflake_role

ARG airflow_aws_access_key_id
ARG airflow_aws_secret_access_key

# SECRET ENVIRONMENT
ENV host=$host
ENV user=$user
ENV password=$password

ENV snowflake_user=$snowflake_user
ENV snowflake_password=$snowflake_password
ENV snowflake_account=$snowflake_account
ENV snowflake_warehouse=$snowflake_warehouse
ENV snowflake_database=$snowflake_database
ENV snowflake_schema=$snowflake_schema
ENV snowflake_role=$snowflake_role

ENV aws_access_key_id=$airflow_aws_access_key_id
ENV aws_secret_access_key=$airflow_aws_secret_access_key